package rules;

import com.ftn.sbnz.model.*;
import com.ftn.sbnz.model.Card;
import com.ftn.sbnz.model.CardScore;
import com.ftn.sbnz.model.Owns;
import com.ftn.sbnz.model.NotOwns;
import com.ftn.sbnz.model.Player;
import com.ftn.sbnz.model.Reveal;
import com.ftn.sbnz.model.Suggestion;
import com.ftn.sbnz.model.GameState;
import com.ftn.sbnz.model.GameStatus;
import com.ftn.sbnz.model.Profile;
import com.ftn.sbnz.model.ProfileType;
import com.ftn.sbnz.model.RoomFocus;
import com.ftn.sbnz.model.PriorityCard;
import com.ftn.sbnz.model.StrategicRecommendation;
import com.ftn.sbnz.model.CardType;
import com.ftn.sbnz.model.RiskWarning;
import com.ftn.sbnz.model.RiskLevel;
import com.ftn.sbnz.model.ShowRecommendation;
import com.ftn.sbnz.model.SuggestCard;
import com.ftn.sbnz.model.HighSuspicion;
import com.ftn.sbnz.model.KnowsCard;
import com.ftn.sbnz.model.OptimalAction;

// ============================================================================
// 6.4 - BACKWARD CHAINING STRATEGY VERIFICATION (STRATEGIC SYSTEM - LEVEL 4)
// ============================================================================

// ============================================================================
// 6.4.1 + 6.4.4 - Main strategic decision
// ============================================================================

// Rule that determines optimal suggestion based on all checks
rule "6.4.1 - DETERMINE OPTIMAL SUGGESTION - COMPLETE"
salience 10
when
    // Uzmi sve tri preporuke iz SuggestCard
    $suspectSug: SuggestCard(category == CardType.SUSPECT, $suspect: card)
    $weaponSug: SuggestCard(category == CardType.WEAPON, $weapon: card)
    $roomSug: SuggestCard(category == CardType.ROOM, $room: card)

    // Provera: NizakRizikOtkrivanja - nema HIGH risk
    not RiskWarning(level == RiskLevel.HIGH)

    // Provera: EliminišeKandidate - bar jedna karta je nepoznata (score > 0) i nije Owns
    (CardScore(card == $suspect, score > 0) and not Owns(card == $suspect))
    or (CardScore(card == $weapon, score > 0) and not Owns(card == $weapon))
    or (CardScore(card == $room, score > 0))

    // Provera: VisokInformacioniDobitak - karta sa maksimalnim score-om (opciono)
    // Nije obavezno za sve tri karte

    not OptimalAction(action == "SUGGESTION")
then
    insert(new OptimalAction("SUGGESTION", $suspect, $weapon, $room,
        "Optimal suggestion: " + $suspect.getName() + ", " + $weapon.getName() + ", " + $room.getName()));
    System.out.println("[6.4.1] OPTIMAL SUGGESTION: " + $suspect.getName() + ", " + $weapon.getName() + ", " + $room.getName());
end

// Rule that determines optimal show action
rule "6.4.1 - DETERMINE OPTIMAL SHOW"
salience 10
when
    $showRec: ShowRecommendation($card: card)
    $p: Player(self == true)
    Reveal(revealer == $p, card == $card)
    KnowsCard(card == $card)
    not OptimalAction(action == "SHOW")
then
    insert(new OptimalAction("SHOW", $card, null,
        "Showing " + $card.getName() + " is optimal - opponent already knows it"));
    System.out.println("[6.4.1] OPTIMAL SHOW: " + $card.getName());
end

// Rule that determines optimal accusation with complete combination
rule "6.4.1 - DETERMINE OPTIMAL ACCUSATION"
salience 10
when
    GameState(status == GameStatus.LATE_GAME)
    $suspect: Card(type == CardType.SUSPECT)
    $suspectScore: CardScore(card == $suspect, score > 0)
    not Card(type == CardType.SUSPECT, this != $suspect) and
    not CardScore(card != $suspect, card.getType() == CardType.SUSPECT, score > 0)

    $weapon: Card(type == CardType.WEAPON)
    $weaponScore: CardScore(card == $weapon, score > 0)
    not Card(type == CardType.WEAPON, this != $weapon) and
    not CardScore(card != $weapon, card.getType() == CardType.WEAPON, score > 0)

    $room: Card(type == CardType.ROOM)
    $roomScore: CardScore(card == $room, score > 0)
    not Card(type == CardType.ROOM, this != $room) and
    not CardScore(card != $room, card.getType() == CardType.ROOM, score > 0)

    not OptimalAction(action == "ACCUSE")
then
    insert(new OptimalAction("ACCUSE", $suspect, $weapon, $room,
        "Final accusation ready! Only remaining cards: " +
        $suspect.getName() + ", " + $weapon.getName() + ", " + $room.getName()));
end

// Default strategy - if no optimal action found
rule "6.4.4 - DEFAULT STRATEGY"
salience 1
when
    GameState($status: status)
    not OptimalAction()
    $sugCard: SuggestCard($card: card, $category: category)
then
    insert(new OptimalAction("DEFAULT", $card, $category,
        "Default strategy: " + $card.getName()));
    System.out.println("[6.4.4] DEFAULT ACTION: " + $card.getName());
end

// Display the final recommendation
rule "6.4.4 - DISPLAY RECOMMENDATION"
when
    $opt: OptimalAction($action: action, $reasoning: reasoning)
    $gameState: GameState()
then
    System.out.println("========================================");
    System.out.println("FINAL RECOMMENDATION:");
    System.out.println("ACTION: " + $action);
    if ("ACCUSE".equals($action)) {
        System.out.println("SUSPECT: " + $opt.getSuspect().getName());
        System.out.println("WEAPON: " + $opt.getWeapon().getName());
        System.out.println("ROOM: " + $opt.getRoom().getName());
    } else if ($opt.getCard() != null) {
        System.out.println("CARD: " + $opt.getCard().getName());
    }
    System.out.println("REASON: " + $reasoning);
    System.out.println("========================================");
end