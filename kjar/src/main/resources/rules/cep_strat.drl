//            + $p.getName() + " zna)");
//end


// ============================================================================
// SESTO: CEP utice na stratešku preporuku (salience 5)
// FIX: marker po HighSuspicion karti, da ne re-pišemo preporuku za istu kartu.
//      Ako više karata ima HighSuspicion, preporuka se piše više puta -
//      ali poslednja "pobeđuje" jer prepisuje prethodnu (retract).
// ============================================================================
rule "CEP UTICE NA STRATESKU PREPORUKU"
salience 5
when
    $hs: HighSuspicion($c: card)
    $state: GameState()
    $strat: StrategicRecommendation(phase == $state.getStatus())
    not ScoreApplied(ruleId == "CEP_REC", key == $c.getName())
then
    retract($strat);
    insert(new StrategicRecommendation(
        $state.getStatus(),
        "CEP PREPORUKA: Fokusiraj se na " + $c.getName() +
        " zbog visoke sumnje od strane protivnika"
    ));
    insert(new ScoreApplied("CEP_REC", $c.getName()));
    System.out.println("CEP: Izmenjena strateška preporuka za " + $c.getName());
end


// ============================================================================
// SEDMO: Agresivan protivnik - povecaj oprez (salience 5)
// FIX: marker po protivniku.
// ============================================================================
rule "AGRESIVAN PROTIVNIK - POVECAN OPREZ"
salience 5
when
    GameState(status == GameStatus.LATE_GAME)
    Profile($p: player, profile == ProfileType.AGGRESSIVE)
    not RiskWarning(level == RiskLevel.HIGH)
    not RiskWarning(level == RiskLevel.MEDIUM, cause == $p)
    not ScoreApplied(ruleId == "AGG_WARN", key == $p.getName())
then
    insert(new RiskWarning(RiskLevel.MEDIUM, $p,
        "OPREZ: Igrač " + $p.getName() + " je agresivan u kasnoj igri!"));
    insert(new ScoreApplied("AGG_WARN", $p.getName()));
    System.out.println("CEP OPREZ: Agresivan protivnik " + $p.getName());
end


// ============================================================================
// REMOVE OLD PROFILE WHEN NEW ONE IS ADDED
// NAPOMENA: ovo pravilo je opasno - 'this != $newProfile' samo veže dva
// različita Profile objekta, ali ne kaže koja je stara koja je nova.
// U najgorem slučaju retract-uje pogrešnog (možda novog koji je upravo dodat).
//
// FIX: koristimo timestamp marker - novi profile ima ScoreApplied marker
// koji ga štiti od retract-a. Bez markera = stari profile = bezbedno retract.
//
// ALTERNATIVA (preporučena): obrisati ovo pravilo i dozvoliti da igrač
// može imati više profila istovremeno (BLUFFING + AGGRESSIVE). Ipak,
// to su različita ponašanja koja se mogu javiti zajedno.
// ============================================================================
rule "REMOVE OLD PROFILE WHEN NEW IS ADDED"
when
    $p: Player()

    $newProfile: Profile(player == $p)

    $oldProfile: Profile(player == $p)

    not ProfileProcessed(player == $p)
then
    retract($oldProfile);

    insert(new ProfileProcessed($p));

    System.out.println("REMOVED OLD PROFILE for " + $p.getName());
end
