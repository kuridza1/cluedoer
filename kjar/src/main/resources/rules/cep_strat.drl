package rules;

import com.ftn.sbnz.model.*;
import com.ftn.sbnz.model.Card;
import com.ftn.sbnz.model.CardScore;
import com.ftn.sbnz.model.Owns;
import com.ftn.sbnz.model.NotOwns;
import com.ftn.sbnz.model.Player;
import com.ftn.sbnz.model.Reveal;
import com.ftn.sbnz.model.Suggestion;
import com.ftn.sbnz.model.GameState;
import com.ftn.sbnz.model.GameStatus;
import com.ftn.sbnz.model.Profile;
import com.ftn.sbnz.model.ProfileType;
import com.ftn.sbnz.model.RoomFocus;
import com.ftn.sbnz.model.PriorityCard;
import com.ftn.sbnz.model.StrategicRecommendation;
import com.ftn.sbnz.model.CardType;
import com.ftn.sbnz.model.RiskWarning;
import com.ftn.sbnz.model.RiskLevel;
import com.ftn.sbnz.model.ShowRecommendation;
import com.ftn.sbnz.model.SuggestCard;
import com.ftn.sbnz.model.HighSuspicion;
import com.ftn.sbnz.model.KnowsCard;
import com.ftn.sbnz.model.ScoreApplied;
import com.ftn.sbnz.model.ProfileProcessed;
// ============================================================================
// 6.3 - CEP ANALIZA PONAŠANJA (STRATEŠKI SISTEM - NIVO 3)
//
// NAPOMENA O ISPRAVKAMA (verzija 2):
// - Sva pravila koja menjaju CardScore koriste 'modify' umesto 'retract+insert'.
// - Sva pravila imaju ScoreApplied marker da se ne aktiviraju više puta
//   za istu kombinaciju (pravilo + karta + igrač). Ovo sprečava da iste
//   činjenice (npr. KnowsCard za istu kartu) iznova okidaju Score modifikaciju.
// - Marker pattern je usaglašen sa onim iz cep_deduct.drl (5.2.3a/b/c/4).
// ============================================================================


// ============================================================================
// 6.3.1 - Detekcija visoke sumnje kada igrač koristi istu kartu u više uzastopnih sugestija
// ============================================================================
rule "6.3.1 - VISOKA SUMNJA - ISTA KARTA U VISE UZASTOPNIH SUGESTIJA"
when
    $p: Player(self == false)
    $c: Card()

    $sug1: Suggestion(suggester == $p,
                      (suspect == $c || weapon == $c || room == $c))
    $sug2: Suggestion(suggester == $p, this != $sug1,
                      (suspect == $c || weapon == $c || room == $c))
    $sug3: Suggestion(suggester == $p, this != $sug1 && this != $sug2,
                      (suspect == $c || weapon == $c || room == $c))

    not HighSuspicion(player == $p, card == $c)
then
    insert(new HighSuspicion($p, $c));
    System.out.println("[6.3.1] VISOKA SUMNJA - " + $p.getName() +
                       " koristi " + $c.getName() + " u vise uzastopnih sugestija");
end


// ============================================================================
// 6.3.2 - Detekcija blefiranja kada igrač više puta koristi kartu koju sigurno poseduje
// ============================================================================
rule "6.3.2 - BLEFIRANJE - VISE PUTA KORISTI SOPSTVENU KARTU"
when
    $p: Player(self == false)
    $c: Card()

    Owns(player == $p, card == $c)

    $count: Number(intValue >= 2) from accumulate(
        Suggestion(suggester == $p,
                   suspect == $c || weapon == $c || room == $c),
        count(1)
    )

    not Profile(player == $p, profile == ProfileType.BLUFFING)

then
    insert(new Profile($p, ProfileType.BLUFFING));
    System.out.println("[6.3.2] BLEFIRANJE - " + $p.getName() +
                       " vise puta koristi sopstvenu kartu " + $c.getName());
end


// ============================================================================
// 6.3.3 - Detekcija agresivnog profila u kasnoj igri
// ============================================================================
rule "6.3.3 - AGRESIVAN PROFIL - NAGLA PROMENA OBRASCA U KASNOJ IGRI"
when
    GameState(status == GameStatus.LATE_GAME)
    $p: Player(self == false)

    $sug1: Suggestion(suggester == $p)
    $sug2: Suggestion(suggester == $p, this != $sug1)

    eval($sug1.getSuspect() != $sug2.getSuspect() ||
         $sug1.getWeapon() != $sug2.getWeapon() ||
         $sug1.getRoom() != $sug2.getRoom())

    not Profile(player == $p, profile == ProfileType.AGGRESSIVE)
then
    insert(new Profile($p, ProfileType.AGGRESSIVE));
    System.out.println("[6.3.3] AGRESIVAN PROFIL - " + $p.getName() +
                       " naglo promenio obrazac sugestija u kasnoj igri");
end


// ============================================================================
// 6.3.4 - Zaključak da protivnik zna za kartu
// ============================================================================
rule "6.3.4 - VEROVATNO ZNA ZA KARTU - PRESTAO DA KORISTI"
when
    $p: Player(self == false)
    $c: Card()

    // Igrač je koristio kartu u NAJMANJE 2 sugestije (ne samo 1!)
    $count: Number(intValue >= 2) from accumulate(
        Suggestion(suggester == $p,
                   suspect == $c || weapon == $c || room == $c),
        count(1)
    )

    // Prestao je da je koristi u novijim sugestijama
    $lastSug: Suggestion(suggester == $p,
                         suspect == $c || weapon == $c || room == $c)
    not Suggestion(suggester == $p, this after $lastSug,
                   suspect == $c || weapon == $c || room == $c)

    CardScore(card == $c, score > 0)
    CardScore(card == $c, score < 50)

    not KnowsCard(player == $p, card == $c)
then
    insert(new KnowsCard($p, $c));
    System.out.println("[6.3.4] VEROVATNO ZNA - " + $p.getName() +
                       " prestao da koristi " + $c.getName() + " (koristio je " + $count + " puta)");
end


// ============================================================================
// 6.3.5 - Detekcija fokusa na prostoriju
// ============================================================================
rule "6.3.5 - FOKUS NA PROSTORIJU - ISTA PROSTORIJA"
when
    $p: Player(self == false)
    $r: Card(type == CardType.ROOM)

    $sug1: Suggestion(suggester == $p, room == $r)
    $sug2: Suggestion(suggester == $p, room == $r, this != $sug1)

    not RoomFocus(player == $p, room == $r)
then
    insert(new RoomFocus($p, $r));
    System.out.println("[6.3.5] FOKUS NA PROSTORIJU - " + $p.getName() +
                       " cesto koristi " + $r.getName());
end


// ============================================================================
// CEP PRAVILA ZA KORISCENJE INFORMACIJA - SA salience ZA REDOSLED
// ============================================================================

// ============================================================================
// PRVO: Korekcija score-a za fokusirane prostorije (salience 20)
// FIX: 'modify' umesto 'retract+insert'. Marker po (RoomFocus, prostorija) -
//      svaki RoomFocus se računa jednom, čak i ako više igrača ima fokus.
// ============================================================================
rule "KORIGUJ SCORE ZA FOKUS"
salience 20
when
    $rf: RoomFocus($p: player, $r: room)
    $cs: CardScore(card == $r, score > 0)
    not ScoreApplied(ruleId == "FOCUS_BONUS", key == ($p.getName() + ":" + $r.getName()))
then
    modify($cs) { setScore($cs.getScore() + 2) };
    insert(new ScoreApplied("FOCUS_BONUS", $p.getName() + ":" + $r.getName()));
    System.out.println("CEP KOREKCIJA: +2 score za " + $r.getName()
            + " (fokus " + $p.getName() + ")");
end


// ============================================================================
// DRUGO: Prioritet visoke sumnje (salience 15)
// FIX: marker da se ne pravi duplikat SuggestCard za isti par (HighSuspicion, karta).
// ============================================================================
rule "PRIORITIZUJ VISOKU SUMNJU"
salience 15
when
    $hs: HighSuspicion($c: card)
    not SuggestCard(category == $c.getType(), card == $c)
    not ScoreApplied(ruleId == "PRIORITIZE", key == $c.getName())
then
    insert(new SuggestCard($c.getType(), $c));
    insert(new ScoreApplied("PRIORITIZE", $c.getName()));
    System.out.println("CEP PRIORITET: " + $c.getName() + " (visoka sumnja)");
end


// ============================================================================
// TRECE: Izbegavanje karata koje protivnik zna u kasnoj igri (salience 15)
// FIX: marker da ne uđemo u petlju kad PRIORITIZUJ ponovo doda istu SuggestCard.
// ============================================================================
rule "IZBEGAVAJ KARTU - KASNA IGRA"
salience 15
when
    $kc: KnowsCard($c: card)
    GameState(status == GameStatus.LATE_GAME)
    $sug: SuggestCard(card == $c)
    not ScoreApplied(ruleId == "AVOID_KNOWN", key == $c.getName())
then
    retract($sug);
    insert(new ScoreApplied("AVOID_KNOWN", $c.getName()));
    System.out.println("CEP IZBEGAVAM: " + $c.getName() + " jer protivnik zna za nju");
end


// ============================================================================
// CETVRTO: Povećaj score za karte koje su pod visokom sumnjom (salience 10)
// FIX: 'modify' + marker. Bonus se primenjuje jednom po (sumnjičar, karta).
// ============================================================================
rule "POVECAJ SCORE ZA VISOKU SUMNJU"
salience 10
when
    $hs: HighSuspicion($p: player, $c: card)
    $cs: CardScore(card == $c, score > 0, score < 5)
    not ScoreApplied(ruleId == "BUMP_SUSPICION", key == ($p.getName() + ":" + $c.getName()))
then
    modify($cs) { setScore($cs.getScore() + 1) };
    insert(new ScoreApplied("BUMP_SUSPICION", $p.getName() + ":" + $c.getName()));
    System.out.println("CEP: +1 score za " + $c.getName() + " (visoka sumnja od "
            + $p.getName() + ")");
end


// ============================================================================
// PETO: Smanji score za karte koje protivnik zna (salience 10)
//
// GLAVNA ISPRAVKA: ovo je pravilo koje je ranije ulazilo u beskonačnu petlju
// (retract + insert je svaki put pravio novi CardScore objekat, koji je
// ponovo trigerovao pravilo, sve dok score nije pao na 0).
//
// FIX: 'modify' + marker po (KnowsCard, karta). Penalizacija se primenjuje
// jednom po protivniku koji "zna", bez obzira na to koliko puta okidači
// budu reaktivirani.
// ============================================================================
