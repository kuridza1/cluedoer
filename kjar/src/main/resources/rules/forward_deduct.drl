package rules;

import com.ftn.sbnz.model.Card;
import com.ftn.sbnz.model.CardType;
import com.ftn.sbnz.model.CardScore;
import com.ftn.sbnz.model.Owns;
import com.ftn.sbnz.model.NotOwns;
import com.ftn.sbnz.model.Player;
import com.ftn.sbnz.model.Reveal;
import com.ftn.sbnz.model.NoShow;
import com.ftn.sbnz.model.Solution;
import com.ftn.sbnz.model.Suggestion;
import com.ftn.sbnz.model.PrivateShow;

// ============================================================================
// NIVO 1 - Forward chaining (monotona dedukcija)
// Iz proposala, sekcija 5.1
// ============================================================================
// Pravila ovog nivoa izvode nove činjenice o vlasništvu karata i sadržaju
// koverte iz već utvrđenih činjenica. Zaključci su monotoni - jednom izvedena
// činjenica se ne povlači.
// ============================================================================


// ----------------------------------------------------------------------------
// 5.1.1 Sopstvene karte
// IF X ∈ Karte(ja) THEN Score(X) = 0 AND Rešenje(K) != X
// ----------------------------------------------------------------------------

rule "5.1.1 - Sopstvena karta: Score = 0"
    when
        $o: Owns($player: player, $card: card)
        Player(this == $player, self == true)
        $s: CardScore(card == $card, score != 0)
    then
        modify($s) { setScore(0) };
        System.out.println("[5.1.1] Sopstvena karta -> Score(" + $card.getName() + ") = 0");
end

// Generalniji pandan (važi i za karte drugih igrača): jednom kad znamo da
// karta pripada nekome u igri, ona ne može biti u koverti -> Score = 0.
rule "5.1.2a - Karta poznatog vlasnika: Score = 0"
    when
        Owns($card: card)
        $s: CardScore(card == $card, score != 0)
    then
        modify($s) { setScore(0) };
        System.out.println("[5.1.2a] Karta je u igri -> Score(" + $card.getName() + ") = 0");
end


// ----------------------------------------------------------------------------
// 5.1.2 Karte protivnika
// ----------------------------------------------------------------------------

// IF protivnik A pokaže kartu X THEN X ∈ Karte(A) AND Score(X) = 0
rule "5.1.2b - Reveal -> Owns"
    when
        $r: Reveal($p: revealer, $c: card)
        not Owns(player == $p, card == $c)
    then
        insert(new Owns($p, $c));
        System.out.println("[5.1.2b] " + $p.getName() + " je pokazao -> Owns(" + $c.getName() + ")");
end

// IF X ∈ Karte(A) THEN ∀ B != A : X ∉ Karte(B)
// (Eksluzivnost vlasništva - svaka karta postoji u tačno jednom primerku.)
rule "5.1.2c - Owns(A,X) -> NotOwns(B,X) za sve B != A"
    when
        Owns($owner: player, $card: card)
        $other: Player(this != $owner)
        not NotOwns(player == $other, card == $card)
    then
        insert(new NotOwns($other, $card));
        System.out.println("[5.1.2c] " + $card.getName() + " pripada "
                + $owner.getName() + " -> NotOwns(" + $other.getName() + ", " + $card.getName() + ")");
end

// IF protivnik A nije pokazao nijednu kartu na pretpostavku (X, Y, Z)
//    THEN {X, Y, Z} ∩ Karte(A) = ∅
// Razlažemo u tri NotOwns činjenice (po jedna za S, W, R iz sugestije).
rule "5.1.2d - NoShow -> NotOwns za suspect"
    when
        NoShow($p: player, $sug: suggestion)
        $card: Card() from $sug.getSuspect()
        not NotOwns(player == $p, card == $card)
    then
        insert(new NotOwns($p, $card));
        System.out.println("[5.1.2d] " + $p.getName() + " nije pokazao -> NotOwns("
                + $p.getName() + ", " + $card.getName() + ")");
end

rule "5.1.2d - NoShow -> NotOwns za weapon"
    when
        NoShow($p: player, $sug: suggestion)
        $card: Card() from $sug.getWeapon()
        not NotOwns(player == $p, card == $card)
    then
        insert(new NotOwns($p, $card));
        System.out.println("[5.1.2d] " + $p.getName() + " nije pokazao -> NotOwns("
                + $p.getName() + ", " + $card.getName() + ")");
end

rule "5.1.2d - NoShow -> NotOwns za room"
    when
        NoShow($p: player, $sug: suggestion)
        $card: Card() from $sug.getRoom()
        not NotOwns(player == $p, card == $card)
    then
        insert(new NotOwns($p, $card));
        System.out.println("[5.1.2d] " + $p.getName() + " nije pokazao -> NotOwns("
                + $p.getName() + ", " + $card.getName() + ")");
end


// ----------------------------------------------------------------------------
// 5.1.3 Neotkrivene karte i sadržaj koverte
// ----------------------------------------------------------------------------

// IF X ∈ K (po kategoriji) AND ∀ igrač A : X ∉ Karte(A) THEN Rešenje(K) = X
// Implementacija: ako za kartu X nijedan igrač nije njen vlasnik, A SVI igrači
// imaju NotOwns(X), onda X mora biti u koverti.
//
// Koristimo accumulate da prebrojimo igrače i NotOwns činjenice za datu kartu.
rule "5.1.3a - Karta koju niko ne poseduje je u koverti"
    when
        $c: Card()
        not Owns(card == $c)
        $totalPlayers: Number() from accumulate(
            Player($p: this),
            count($p)
        )
        $notOwners: Number(this == $totalPlayers) from accumulate(
            NotOwns(card == $c, $p: player),
            count($p)
        )
        not Solution(card == $c)
    then
        insert(new Solution($c));
        System.out.println("[5.1.3a] Niko ne poseduje " + $c.getName() + " -> Solution(" + $c.getName() + ")");
end

// IF |Kandidati(K)| = 1 AND Kandidati(K) = {X} THEN Rešenje(K) = X
// Kandidat = karta date kategorije koja još nije eliminisana (Score > 0).
// Ako za neku kategoriju postoji tačno jedna takva karta, ona je rešenje.
rule "5.1.3b - Jedini kandidat u kategoriji je u koverti"
    when
        $t: CardType()
        $count: Number(intValue == 1) from accumulate(
            CardScore($card: card, score > 0)
            and Card(this == $card, type == $t),
            count($card)
        )
        $sc: CardScore($winner: card, score > 0)
        Card(this == $winner, type == $t)
        not Solution(card == $winner)
    then
        insert(new Solution($winner));
        System.out.println("[5.1.3b] Jedini kandidat u kategoriji " + $t
                + " -> Solution(" + $winner.getName() + ")");
end


// ----------------------------------------------------------------------------
// Pomoćno pravilo - Solution -> NotOwns za sve igrače
// Karta u koverti ne može biti ni u rukama bilo kog igrača. Ovo pomaže
// drugim pravilima jer obezbeđuje konzistenciju modela.
// ----------------------------------------------------------------------------
rule "Solution -> NotOwns za sve igrače"
    when
        Solution($c: card)
        $p: Player()
        not NotOwns(player == $p, card == $c)
    then
        insert(new NotOwns($p, $c));
        System.out.println("[Sol->NotOwns] Solution(" + $c.getName()
                + ") -> NotOwns(" + $p.getName() + ", " + $c.getName() + ")");
end

// ----------------------------------------------------------------------------
// PrivateShow dedukcija
// IF P je pokazao NEKU kartu iz sugestije (S, W, R), AND
//    znamo da P nema S, AND
//    znamo da P nema W,
// THEN P mora imati R.
// (i analogno za druge dve permutacije)
// ----------------------------------------------------------------------------

rule "PrivateShow: dve od tri eliminisane -> treca je Owns (suspect ostao)"
    when
        $ps: PrivateShow($p: shower, $sug: suggestion)
        $sCard: Card() from $sug.getSuspect()
        $wCard: Card() from $sug.getWeapon()
        $rCard: Card() from $sug.getRoom()
        NotOwns(player == $p, card == $wCard)
        NotOwns(player == $p, card == $rCard)
        not Owns(player == $p, card == $sCard)
    then
        insert(new Owns($p, $sCard));
        System.out.println("[PrivateShow] " + $p.getName()
                + " je pokazao neku iz " + $sug + ", a nema W ni R -> Owns("
                + $sCard.getName() + ")");
end

rule "PrivateShow: dve od tri eliminisane -> treca je Owns (weapon ostao)"
    when
        $ps: PrivateShow($p: shower, $sug: suggestion)
        $sCard: Card() from $sug.getSuspect()
        $wCard: Card() from $sug.getWeapon()
        $rCard: Card() from $sug.getRoom()
        NotOwns(player == $p, card == $sCard)
        NotOwns(player == $p, card == $rCard)
        not Owns(player == $p, card == $wCard)
    then
        insert(new Owns($p, $wCard));
        System.out.println("[PrivateShow] " + $p.getName()
                + " je pokazao neku iz " + $sug + ", a nema S ni R -> Owns("
                + $wCard.getName() + ")");
end

rule "PrivateShow: dve od tri eliminisane -> treca je Owns (room ostao)"
    when
        $ps: PrivateShow($p: shower, $sug: suggestion)
        $sCard: Card() from $sug.getSuspect()
        $wCard: Card() from $sug.getWeapon()
        $rCard: Card() from $sug.getRoom()
        NotOwns(player == $p, card == $sCard)
        NotOwns(player == $p, card == $wCard)
        not Owns(player == $p, card == $rCard)
    then
        insert(new Owns($p, $rCard));
        System.out.println("[PrivateShow] " + $p.getName()
                + " je pokazao neku iz " + $sug + ", a nema S ni W -> Owns("
                + $rCard.getName() + ")");
end