package rules;

import com.ftn.sbnz.model.Card;
import com.ftn.sbnz.model.CardType;
import com.ftn.sbnz.model.CardScore;
import com.ftn.sbnz.model.Owns;
import com.ftn.sbnz.model.NotOwns;
import com.ftn.sbnz.model.Player;
import com.ftn.sbnz.model.Reveal;
import com.ftn.sbnz.model.NoShow;
import com.ftn.sbnz.model.Solution;
import com.ftn.sbnz.model.Suggestion;
import com.ftn.sbnz.model.PrivateShow;
import com.ftn.sbnz.model.AppliedRule;

declare Suggestion
    @role(event)
    @timestamp(timestamp)
    @expires(2h)
end

declare Reveal
    @role(event)
    @timestamp(timestamp)
    @expires(2h)
end

declare NoShow
    @role(event)
    @timestamp(timestamp)
    @expires(2h)
end

declare PrivateShow
    @role(event)
    @timestamp(timestamp)
    @expires(2h)
end

rule "5.1.1 - Sopstvena karta: Score = 0"
    when
        $o: Owns($player: player, $card: card)
        Player(this == $player, self == true)
        $s: CardScore(card == $card, score != 0)
        not AppliedRule(ruleId == "5.1.1")
    then
        modify($s) { setScore(0) };
        insert(new AppliedRule("5.1.1", $card.getName()));
end

rule "5.1.2a - Karta u igri: Score = 0"
    when
        Owns($card: card)
        $s: CardScore(card == $card, score != 0)
        not AppliedRule(ruleId == "5.1.2a", detail == $card.getName())
    then
        modify($s) { setScore(0) };
        insert(new AppliedRule("5.1.2a", $card.getName()));
end

rule "5.1.2b - Reveal -> Owns"
    when
        $r: Reveal($p: revealer, $c: card)
        not Owns(player == $p, card == $c)
    then
        insert(new Owns($p, $c));
        insert(new AppliedRule("5.1.2b", $p.getName() + " -> " + $c.getName()));
end

rule "5.1.2c - Owns(A,X) -> NotOwns(B,X) za sve B != A"
    when
        Owns($owner: player, $card: card)
        $other: Player(this != $owner)
        not NotOwns(player == $other, card == $card)
    then
        insert(new NotOwns($other, $card));
        insert(new AppliedRule("5.1.2c", $other.getName() + " !-> " + $card.getName()));
end

rule "5.1.2e - Sopstvena karta kategorije -> NotOwns nijednu drugu kartu te kategorije"
    when
        Player(self == true, $self: this)
        Owns(player == $self, $ownedCard: card)
        $otherCard: Card(this != $ownedCard)
        not Owns(player == $self, card == $otherCard)
        not NotOwns(player == $self, card == $otherCard)
    then
        insert(new NotOwns($self, $otherCard));
        insert(new AppliedRule("5.1.2e", $self.getName() + " !-> " + $otherCard.getName()));
end

rule "5.1.2f - Protivnik Owns = handSize -> NotOwns ostale karte"
    when
        $p: Player(self == false, $hs: handSize)
        Number(intValue >= $hs) from accumulate(
            Owns(player == $p),
            count(1)
        )
        $card: Card()
        not Owns(player == $p, card == $card)
        not NotOwns(player == $p, card == $card)
    then
        insert(new NotOwns($p, $card));
        insert(new AppliedRule("5.1.2f", $p.getName() + " !-> " + $card.getName()));
end

rule "5.1.3a - Karta koju niko ne poseduje je u koverti"
    when
        $card: Card($cName: name)
        not (
            Player($p: this)
            and not NotOwns(player == $p, card == $card)
        )
        not Solution(card == $card)
    then
        insert(new Solution($card));
        insert(new AppliedRule("5.1.3a", $cName));
        System.out.println("[5.1.3] " + $cName + " je u koverti");
end

rule "5.1.3b - Karta u koverti -> Score = 100"
    when
        $sol: Solution($card: card)
        $cs: CardScore(card == $card, score < 100)
    then
        modify($cs) { setScore(100) };
        insert(new AppliedRule("5.1.3b", $card.getName()));
        System.out.println("[5.1.3b] " + $card.getName() + " Score = 100");
end

rule "5.1.3c - Jedina karta u kategoriji bez NotOwns za sve -> u koverti"
    when
        $type: CardType()
        Number(intValue == 1) from accumulate(
            $c: Card(type == $type)
            and CardScore(card == $c, score > 0)
            and not Solution(card == $c),
            count($c)
        )
        $card: Card(type == $type)
        CardScore(card == $card, score > 0)
        not Solution(card == $card)
        not Owns(card == $card)
    then
        insert(new Solution($card));
        insert(new AppliedRule("5.1.3c", $card.getName()));
        System.out.println("[5.1.3c] " + $card.getName() + " jedini kandidat");
end

rule "5.1.3d - Karta u koverti -> NotOwns za sve igrače"
    when
        Solution($card: card)
        $p: Player()
        not NotOwns(player == $p, card == $card)
    then
        insert(new NotOwns($p, $card));
        insert(new AppliedRule("5.1.3d", $p.getName() + " !-> " + $card.getName()));
        System.out.println("[5.1.3d] " + $card.getName() + " -> NotOwns(" + $p.getName() + ")");
end

rule "5.1.5a - Dedukcija: Preklapanje ruku i eliminacija"
    when
        $p1: Player($hs: handSize, self == false)
        // Igrač 1 ima tačno handSize - 1 poznatih karata
        Number(intValue == ($hs - 1)) from accumulate(
            Owns(player == $p1),
            count(1)
        )
        // Postoji karta X za koju nismo sigurni da li je kod njega, ali je pod sumnjom
        $unknownCard: Card()
        not Owns(player == $p1, card == $unknownCard)
        not NotOwns(player == $p1, card == $unknownCard)

        // Ali saznamo da neki DRUGI igrač poseduje tu kartu X (iz Nivoa 1)
        Owns(player != $p1, card == $unknownCard)
    then
        // Pošto je ta sumnjiva karta kod drugog, igrač 1 je SIGURNO nema
        insert(new NotOwns($p1, $unknownCard));
        insert(new AppliedRule("5.1.5a", $p1.getName() + " !-> " + $unknownCard.getName() + " (Cross-Match)"));
end

rule "5.1.5b - Dedukcija: PrivateShow eksterni dokaz"
    when
        // Imamo zabeležen PrivateShow (neko je nekome pokazao nešto)
        $ps: PrivateShow($p: shower, $sug: suggestion)
        Suggestion(this == $sug, $s: suspect, $w: weapon, $r: room)

        // Znamo iz drugih izvora (Nivo 1) da su npr. Weapon i Room kod nekog trećeg
        Owns(player != $p, card == $w)
        Owns(player != $p, card == $r)

        // A još uvek nemamo direktan dokaz za ovog igrača
        not Owns(player == $p, card == $s)
    then
        // Zaključak: Pošto ostale dve drže drugi ljudi, on je morao pokazati Suspect-a!
        insert(new Owns($p, $s));
        insert(new AppliedRule("5.1.5b", $p.getName() + " ima " + $s.getName() + " (PS Eksterni Dokaz)"));
end

rule "5.1.6a - Meta: Svi vlasnici poznati -> Preostala ide u kovertu"
    when
        $type: CardType()
        $targetCard: Card(type == $type)
        not Solution(card == $targetCard)
        not Owns(card == $targetCard)

        // Brojimo koliko OSTALIH karata iz ove kategorije ima poznatog vlasnika
        Number($totalOthers: intValue) from accumulate(
            $c: Card(type == $type, this != $targetCard),
            count($c)
        )
        Number(intValue == $totalOthers) from accumulate(
            $c: Card(type == $type, this != $targetCard) and Owns(card == $c),
            count(1)
        )
    then
        // Sve ostale karte su podeljene među igračima, ova je tajna!
        insert(new Solution($targetCard));
        insert(new AppliedRule("5.1.6a", $targetCard.getName() + " (Svi vlasnici detektovani)"));
        System.out.println("[NIVO 3] " + $targetCard.getName() + " je u koverti!");
end

