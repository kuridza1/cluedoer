package rules;

import com.ftn.sbnz.model.*;
import com.ftn.sbnz.model.Card;
import com.ftn.sbnz.model.CardScore;
import com.ftn.sbnz.model.Owns;
import com.ftn.sbnz.model.NotOwns;
import com.ftn.sbnz.model.Player;
import com.ftn.sbnz.model.Reveal;
import com.ftn.sbnz.model.Suggestion;
import com.ftn.sbnz.model.GameState;
import com.ftn.sbnz.model.GameStatus;
import com.ftn.sbnz.model.Profile;
import com.ftn.sbnz.model.ProfileType;
import com.ftn.sbnz.model.RoomFocus;
import com.ftn.sbnz.model.PriorityCard;
import com.ftn.sbnz.model.StrategicRecommendation;
import com.ftn.sbnz.model.CardType;
import com.ftn.sbnz.model.RiskWarning;
import com.ftn.sbnz.model.RiskLevel;
import com.ftn.sbnz.model.ShowRecommendation;
import com.ftn.sbnz.model.SuggestCard;
import com.ftn.sbnz.model.ScoreApplied;
import com.ftn.sbnz.model.AppliedRule;


// 6.1.1 - PROFILISANJE PROTIVNIKA

rule "6.1.1 - DEFENSIVE"
when
    $p: Player(self == false)
    $c: Card()
    $count: Number(intValue >= 2) from accumulate(
        Reveal(revealer == $p, card == $c),
        count(1)
    )
    not Profile(player == $p, profile == ProfileType.DEFENSIVE)
then
    for (Object o : kcontext.getKieRuntime().getObjects(
            obj -> obj instanceof Profile && ((Profile) obj).getPlayer() == $p)) {
        kcontext.getKieRuntime().delete(kcontext.getKieRuntime().getFactHandle(o));
    }
    insert(new Profile($p, ProfileType.DEFENSIVE));
    insert(new AppliedRule("6.1.1-DEF", $p.getName() + " je DEFENSIVE"));
    System.out.println("[6.1.1] PROFILE DEFENSIVE -> " + $p.getName());
end

rule "6.1.1 - BLUFFING"
when
    $p: Player(self == false)
    Owns(player == $p, $c: card)
    Suggestion(suggester == $p, (suspect == $c || weapon == $c || room == $c))
    not Profile(player == $p, profile == ProfileType.BLUFFING)
then
    for (Object o : kcontext.getKieRuntime().getObjects(
            obj -> obj instanceof Profile && ((Profile) obj).getPlayer() == $p)) {
        kcontext.getKieRuntime().delete(kcontext.getKieRuntime().getFactHandle(o));
    }
    insert(new Profile($p, ProfileType.BLUFFING));
    insert(new AppliedRule("6.1.1-BLUFF", $p.getName() + " je BLUFFING"));
    System.out.println("[6.1.1] PROFILE BLUFFING -> " + $p.getName());
end

rule "6.3.1 - BLUFFING REDUCES TRUST"
when
    Profile($p: player, profile == ProfileType.BLUFFING)
    $s: Suggestion(suggester == $p)
    $c: CardScore(
        card == $s.suspect || card == $s.weapon || card == $s.room,
        score > 0
    )
    not ScoreApplied(ruleId == "BLUFF_IMPACT", key == $p.getName() + ":" + $c.getCard().getName())
then
    modify($c) {
        setScore($c.getScore() - 1)
    };
    insert(new ScoreApplied("BLUFF_IMPACT", $p.getName() + ":" + $c.getCard().getName()));
    insert(new AppliedRule("BLUFF_IMPACT", $c.getCard().getName() + " (score-1)"));
    System.out.println("BLUFF IMPACT: -" + $c.getCard().getName());
end

rule "6.3.1 - DEFENSIVE SUGGESTIONS INFORMATIVE"
when
    Profile($p: player, profile == ProfileType.DEFENSIVE)
    $s: Suggestion(suggester == $p)
    $c: CardScore(
        card == $s.suspect || card == $s.weapon || card == $s.room,
        score > 0
    )
    not ScoreApplied(ruleId == "DEF_SIGNAL", key == $p.getName() + ":" + $c.getCard().getName())
then
    modify($c) {
        setScore($c.getScore() + 1)
    };
    insert(new ScoreApplied("DEF_SIGNAL", $p.getName() + ":" + $c.getCard().getName()));
    insert(new AppliedRule("DEF_SIGNAL", $c.getCard().getName() + " (score+1)"));
    System.out.println("DEFENSIVE SIGNAL +1 " + $c.getCard().getName());
end

rule "6.3.1 - AGGRESSIVE REDUCES STABILITY"
when
    Profile($p: player, profile == ProfileType.AGGRESSIVE)
    $s: Suggestion(suggester == $p)
    $c: CardScore(
        card == $s.suspect || card == $s.weapon || card == $s.room,
        score > 1
    )
    not ScoreApplied(ruleId == "AGG_VOLATILITY", key == $p.getName() + ":" + $c.getCard().getName())
then
    modify($c) {
        setScore($c.getScore() - 1)
    };
    insert(new ScoreApplied("AGG_VOLATILITY", $p.getName() + ":" + $c.getCard().getName()));
    insert(new AppliedRule("AGG_VOLATILITY", $c.getCard().getName() + " (score-1)"));
end

rule "6.3.3 - ROOM FOCUS BOOST"
when
    RoomFocus($p: player, $r: room)
    $cs: CardScore(card == $r, score > 0)
    not ScoreApplied(ruleId == "ROOM_FOCUS_BOOST", key == $p.getName() + ":" + $r.getName())
then
    modify($cs) {
        setScore($cs.getScore() + 3)
    };
    insert(new ScoreApplied("ROOM_FOCUS_BOOST", $p.getName() + ":" + $r.getName()));
    insert(new AppliedRule("6.3.3", $r.getName() + " (score+3 za fokus)"));
end

rule "6.3.2 - KNOWN CARD PENALTY"
when
    KnowsCard($p: player, $c: card)
    $cs: CardScore(card == $c, score > 0)
    not ScoreApplied(ruleId == "KNOWN_CARD_PENALTY", key == $p.getName() + ":" + $c.getName())
then
    modify($cs) {
        setScore($cs.getScore() - 3)
    };
    insert(new ScoreApplied("KNOWN_CARD_PENALTY", $p.getName() + ":" + $c.getName()));
    insert(new AppliedRule("6.3.2", $c.getName() + " (score-3 jer je poznata)"));
end

rule "6.3.1 - HIGH SUSPICION PENALTY"
when
    HighSuspicion($p: player, $c: card)
    $cs: CardScore(card == $c, score > 0)
    not ScoreApplied(ruleId == "HS_PENALTY", key == $p.getName() + ":" + $c.getName())
then
    modify($cs) {
        setScore($cs.getScore() - 2)
    };
    insert(new ScoreApplied("HS_PENALTY", $p.getName() + ":" + $c.getName()));
    insert(new AppliedRule("6.3.1-PENALTY", $c.getName() + " (score-2 za sumnju)"));
end

rule "6.1.1 - ROOM FOCUS"
when
    $p: Player(self == false)
    $r: Card(type == CardType.ROOM)
    $count: Number(intValue >= 3) from accumulate(
        Suggestion(suggester == $p, room == $r),
        count(1)
    )
    not RoomFocus(player == $p, room == $r)
then
    insert(new RoomFocus($p, $r));
    insert(new AppliedRule("6.1.1-FOCUS", $p.getName() + " fokusira prostoriju " + $r.getName()));
    System.out.println("[6.1.1] ROOM FOCUS -> " + $p.getName() + " fokusira " + $r.getName());
end


// 6.2.1 - PRIORITY CARD

rule "6.2.1 - GLOBAL MAX SCORE"
salience 5
no-loop true
when
    $maxScore: Number() from accumulate(
        CardScore($s: score, score > 0),
        max($s)
    )
    $best: CardScore(
        $card: card,
        score == $maxScore
    )
    not CardScore(
        score == $maxScore,
        card.name < $card.name
    )
    not PriorityCard(card == $card)
then
    for (Object o : kcontext.getKieRuntime().getObjects(obj -> obj instanceof PriorityCard)) {
        kcontext.getKieRuntime().delete(kcontext.getKieRuntime().getFactHandle(o));
    }
    insert(new PriorityCard($card));
    insert(new AppliedRule("6.2.1-MAX", "Novi prioritet " + $card.getName()));
    System.out.println("[6.2.1] PRIORITY CARD -> " + $card.getName() + " (score=" + $maxScore + ")");
end


// 6.2.1 - STRATEGIJA PO FAZI IGRE

rule "6.2.1 - EARLY STRATEGY"
when
    GameState(status == GameStatus.EARLY_GAME)
    $pc: PriorityCard($card: card)
    not StrategicRecommendation(phase == GameStatus.EARLY_GAME)
then
    for (Object o : kcontext.getKieRuntime().getObjects(obj -> obj instanceof StrategicRecommendation)) {
        kcontext.getKieRuntime().delete(kcontext.getKieRuntime().getFactHandle(o));
    }
    insert(new StrategicRecommendation(
        GameStatus.EARLY_GAME,
        "EARLY GAME: maksimizuj informacioni dobitak. Predlozena karta za sugestiju: " + $card.getName()
    ));
    insert(new AppliedRule("6.2.1-STRAT-EARLY", "Preporuka za ranu igru: " + $card.getName()));
    System.out.println("[6.2.1] STRATEGY EARLY -> fokus na " + $card.getName());
end

rule "6.2.1 - MID STRATEGY"
when
    GameState(status == GameStatus.MID_GAME)
    $pc: PriorityCard($card: card)
    not StrategicRecommendation(phase == GameStatus.MID_GAME)
then
    for (Object o : kcontext.getKieRuntime().getObjects(obj -> obj instanceof StrategicRecommendation)) {
        kcontext.getKieRuntime().delete(kcontext.getKieRuntime().getFactHandle(o));
    }
    insert(new StrategicRecommendation(
        GameStatus.MID_GAME,
        "MID GAME: kombinuj poznatu i nepoznatu kartu u sugestiji. Predlozena karta: " + $card.getName()
    ));
    insert(new AppliedRule("6.2.1-STRAT-MID", "Preporuka za srednju igru: " + $card.getName()));
    System.out.println("[6.2.1] STRATEGY MID -> fokus na " + $card.getName());
end

rule "6.2.1 - LATE STRATEGY"
when
    GameState(status == GameStatus.LATE_GAME)
    $pc: PriorityCard($card: card)
    not StrategicRecommendation(phase == GameStatus.LATE_GAME)
then
    for (Object o : kcontext.getKieRuntime().getObjects(obj -> obj instanceof StrategicRecommendation)) {
        kcontext.getKieRuntime().delete(kcontext.getKieRuntime().getFactHandle(o));
    }
    insert(new StrategicRecommendation(
        GameStatus.LATE_GAME,
        "LATE GAME: forsiraj eliminaciju, pripremi finalnu optubu. Predlozena karta: " + $card.getName()
    ));
    insert(new AppliedRule("6.2.1-STRAT-LATE", "Preporuka za kasnu igru: " + $card.getName()));
    System.out.println("[6.2.1] STRATEGY LATE -> fokus na " + $card.getName());
end


// 6.2.2 - IZBOR KARTE ZA POKAZIVANJE

rule "6.2.2 - SHOW ALREADY KNOWN CARD"
when
    $sug: Suggestion($suggester: suggester)
    $p: Player(self == true)
    Owns(player == $p, $c: card)
    eval($sug.getSuspect() == $c || $sug.getWeapon() == $c || $sug.getRoom() == $c)
    Reveal(revealer == $p, card == $c)
    not ShowRecommendation(card == $c, suggestion == $sug)
then
    insert(new ShowRecommendation($c, $sug,
        "Protivnik " + $suggester.getName() + " vec zna za kartu " + $c.getName() + " - minimalan informacioni gubitak"));
    insert(new AppliedRule("6.2.2-KNOWN", "Preporuka za pokazivanje vec poznate: " + $c.getName()));
    System.out.println("[6.2.2] POKAZI (vec znana) -> " + $c.getName() + " sugestoru " + $suggester.getName());
end

rule "6.2.2 - PREFER NON-ROOM"
when
    $sug: Suggestion($suggester: suggester)
    $p: Player(self == true)
    Owns(player == $p, $c: card)
    Card(this == $c, type != CardType.ROOM)
    eval($sug.getSuspect() == $c || $sug.getWeapon() == $c || $sug.getRoom() == $c)
    not ShowRecommendation(suggestion == $sug)
then
    insert(new ShowRecommendation($c, $sug,
        "Preferiramo ne-prostoriju: " + $c.getName() + " (prostorije cuvamo)"));
    insert(new AppliedRule("6.2.2-NONROOM", "Preporuka za pokazivanje ne-prostorije: " + $c.getName()));
    System.out.println("[6.2.2] POKAZI (ne-prostorija) -> " + $c.getName());
end

rule "6.2.2 - DEFENSIVE OPPONENT LOWEST SCORE"
no-loop true
when
    $sug: Suggestion($suspect: suspect, $weapon: weapon, $room: room, $suggester: suggester)
    Profile(player == $suggester, profile == ProfileType.DEFENSIVE)
    $p: Player(self == true)
    $minScore: Number() from accumulate(
        Owns(player == $p, $cx: card)
        and CardScore(card == $cx, $sx: score)
        and eval($cx == $suspect || $cx == $weapon || $cx == $room),
        min($sx)
    )
    Owns(player == $p, $c: card)
    CardScore(card == $c, score == $minScore)
    eval($c == $suspect || $c == $weapon || $c == $room)
    not ShowRecommendation(suggestion == $sug)
then
    insert(new ShowRecommendation($c, $sug,
        "Defanzivan protivnik " + $suggester.getName() + " - pokazi kartu sa najnizim score: " + $c.getName()));
    insert(new AppliedRule("6.2.2-DEFENSIVE-MIN", "Preporuka za defanzivnog sa min score: " + $c.getName()));
    System.out.println("[6.2.2] POKAZI (defanzivan protivnik, min score) -> " + $c.getName());
end


// 6.2.3 - PROCENA RIZIKA

rule "6.2.3 - HIGH RISK WARNING"
salience 10
when
    GameState(status == GameStatus.LATE_GAME)
    Profile($p: player, profile == ProfileType.BLUFFING)
then
    for (Object o : kcontext.getKieRuntime().getObjects(
            obj -> obj instanceof RiskWarning)) {
        kcontext.getKieRuntime().delete(kcontext.getKieRuntime().getFactHandle(o));
    }
    insert(new RiskWarning(RiskLevel.HIGH, $p,
        "UPOZORENJE: Igrač " + $p.getName() + " blefira u kasnoj igri!"));
    insert(new AppliedRule("6.2.3-HIGH", "Visok rizik - blef u kasnoj igri"));
end

rule "6.2.3 - MEDIUM RISK WARNING"
salience 5
when
    GameState(status != GameStatus.LATE_GAME)
    Profile($p: player, profile == ProfileType.BLUFFING)
    not RiskWarning(level == RiskLevel.HIGH)
then
    for (Object o : kcontext.getKieRuntime().getObjects(
            obj -> obj instanceof RiskWarning)) {
        kcontext.getKieRuntime().delete(kcontext.getKieRuntime().getFactHandle(o));
    }
    insert(new RiskWarning(RiskLevel.MEDIUM, $p,
        "NAPOMENA: Igrač " + $p.getName() + " možda blefira."));
    insert(new AppliedRule("6.2.3-MID", "Srednji rizik - potencijalni blef"));
end

rule "6.2.3 - LOW RISK"
salience 1
when
    not Profile(profile == ProfileType.BLUFFING)
    not RiskWarning(level == RiskLevel.HIGH)
    not RiskWarning(level == RiskLevel.MEDIUM)
then
    for (Object o : kcontext.getKieRuntime().getObjects(
            obj -> obj instanceof RiskWarning)) {
        kcontext.getKieRuntime().delete(kcontext.getKieRuntime().getFactHandle(o));
    }
    insert(new RiskWarning(RiskLevel.LOW, null,
        "Nije detektovan rizik. Nastavi prema strategiji."));
    insert(new AppliedRule("6.2.3-LOW", "Nizak rizik"));
end

rule "OWNED CARD - NO SUGGESTION"
salience 25
when
    Owns($p: player, $c: card)
    $cs: CardScore(card == $c, score > 0)
    not ScoreApplied(ruleId == "OWNED_PENALTY", key == $p.getName() + ":" + $c.getName())
then
    modify($cs) {
        setScore(0)
    };
    insert(new ScoreApplied("OWNED_PENALTY", $p.getName() + ":" + $c.getName()));
    insert(new AppliedRule("OWNED_PENALTY", $c.getName() + " (score 0 jer je poseduje " + $p.getName() + ")"));
    System.out.println("OWNED PENALTY: " + $c.getName() + " (poseduje " + $p.getName() + ") -> score 0");
end