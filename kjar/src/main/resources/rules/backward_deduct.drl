package rules;

import com.ftn.sbnz.model.Card;
import com.ftn.sbnz.model.CardType;
import com.ftn.sbnz.model.CardScore;
import com.ftn.sbnz.model.Owns;
import com.ftn.sbnz.model.NotOwns;
import com.ftn.sbnz.model.Player;
import com.ftn.sbnz.model.Reveal;
import com.ftn.sbnz.model.Solution;
import com.ftn.sbnz.model.GameResult;

// ============================================================================
// NIVO 3 - Backward chaining verifikacija rešenja (proposal sekcija 5.3)
// ============================================================================


// ----------------------------------------------------------------------------
// Pomoćni query: "sviIgraciNeposeduju" - karta Y NIJE u rukama nijednog igrača.
// Za svakog igrača P u radnoj memoriji mora postojati NotOwns(P, Y).
// ----------------------------------------------------------------------------
query "sviIgraciNeposeduju" (Card $card)
    // Ne sme da postoji igrač P za kojeg NE znamo NotOwns(P, $card)
    not (
        Player($p: this)
        and
        not NotOwns(player == $p, card == $card)
    )
end


// ----------------------------------------------------------------------------
// Podcilj: "Y ∉ Rešenje(K)" - karta Y NIJE u koverti.
// Iz proposala 5.3.2 prošireno:
//   - Y je u rukama nekog igrača (Owns), ILI
//   - Y je pokazana tokom partije (Reveal), ILI
//   - Za svakog igrača znamo NotOwns(P, Y) - dakle Y mora biti u koverti...
//     ali za eliminaciju Y kao kandidata za neku DRUGU poziciju, dovoljno je
//     da je dokažemo nekim od ova tri uslova
//
// VAŽNO: treći uslov pravi "obrnutu" deduktivnu putanju - ako za sve karte iste
// kategorije osim X znamo da ih niko ne poseduje, X mora biti rešenje.
// ----------------------------------------------------------------------------
query "nijeResenje" (Card $card)
    (
        // Uslov 1: kartu poseduje neki igrač
        Owns(card == $card)
    ) or (
        // Uslov 2: karta je pokazana tokom partije
        Reveal(card == $card)
    ) or (
        // Uslov 3: za svakog igrača imamo NotOwns za ovu kartu
        // (znači karta nije ni u jednoj ruci -> mora biti u koverti, ali
        // to je ipak validan dokaz da nije "rešenje neke druge karte")
        // NAPOMENA: ovaj uslov se koristi i kad karta JESTE u koverti -
        // tada nije rešenje drugih kategorija. Eliminacija u jesteResenje
        // se oslanja na to da je tačno jedna karta po kategoriji preostala.
        sviIgraciNeposeduju($card;)
    )
end


// ----------------------------------------------------------------------------
// Podcilj: "Rešenje(K) = X" - karta X JESTE rešenje u svojoj kategoriji.
// X je rešenje akko su SVE ostale karte iste kategorije eliminisane.
// ----------------------------------------------------------------------------
query "jesteResenje" (Card $card)

    Card(this == $card, $type: type)

    // Ne sme da postoji druga karta iste kategorije
    // koja još nije eliminisana
    not (
        Card(this != $card, type == $type, $other: this)
        and
        not nijeResenje($other;)
    )
end


// ----------------------------------------------------------------------------
// Glavni query: "resenje" - dokazuje finalnu trojku (S*, W*, R*).
// ----------------------------------------------------------------------------
query "resenje" (Card $suspect, Card $weapon, Card $room)

    Card(this == $suspect, type == CardType.SUSPECT)
    jesteResenje($suspect;)

    Card(this == $weapon, type == CardType.WEAPON)
    jesteResenje($weapon;)

    Card(this == $room, type == CardType.ROOM)
    jesteResenje($room;)
end


// ----------------------------------------------------------------------------
// Pravilo koje POKREĆE backward chaining.
// ----------------------------------------------------------------------------
rule "5.3.3 - Backward verifikacija: proglasi konacno resenje"
    when
        resenje($s, $w, $r;)
        not GameResult()
    then
        GameResult result = new GameResult($s, $w, $r, true);

        insert(result);

        insert(new Solution($s));
        insert(new Solution($w));
        insert(new Solution($r));

        System.out.println(
            "[5.3.3] Backward chaining POTVRDIO resenje: "
            + $s.getName() + " | "
            + $w.getName() + " | "
            + $r.getName()
        );
end