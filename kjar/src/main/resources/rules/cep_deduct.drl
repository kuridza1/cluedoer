package rules;

import com.ftn.sbnz.model.Card;
import com.ftn.sbnz.model.CardType;
import com.ftn.sbnz.model.CardScore;
import com.ftn.sbnz.model.Owns;
import com.ftn.sbnz.model.NotOwns;
import com.ftn.sbnz.model.Player;
import com.ftn.sbnz.model.Reveal;
import com.ftn.sbnz.model.NoShow;
import com.ftn.sbnz.model.PrivateShow;
import com.ftn.sbnz.model.Solution;
import com.ftn.sbnz.model.Suggestion;
import com.ftn.sbnz.model.ScoreApplied;
import com.ftn.sbnz.model.AppliedRule;

declare Suggestion
    @role(event)
    @timestamp(timestamp)
    @expires(2h)
end

declare Reveal
    @role(event)
    @timestamp(timestamp)
    @expires(2h)
end

declare NoShow
    @role(event)
    @timestamp(timestamp)
    @expires(2h)
end

declare PrivateShow
    @role(event)
    @timestamp(timestamp)
    @expires(2h)
end

declare ScoreApplied
    @role(event)
    @expires(2h)
end

// REŠEN MEMORY LEAK: Dodata deklaracija za automatsko brisanje AppliedRule iz memorije
declare AppliedRule
    @role(event)
    @expires(2h)
end

// ==========================================
// CEP PRAVILA (5.2.3x)
// ==========================================

rule "5.2.3a - Karta u 4+ sugestija u 20min bez Reveal-a -> Score += 2"
    when
        $card: Card($cName: name)
        Number(intValue >= 4) from accumulate(
            $s: Suggestion(suspect == $card || weapon == $card || room == $card)
                over window:time(20m),
            count($s)
        )
        not Reveal(card == $card)
        $cs: CardScore(card == $card, score > 0, score < 100)
        not ScoreApplied(ruleId == "5.2.3a", key == $cName)
    then
        modify($cs) { setScore($cs.getScore() + 2) };
        insert(new ScoreApplied("5.2.3a", $cName));
        insert(new AppliedRule("5.2.3a", $cName + " (score+2)"));
        System.out.println("[5.2.3a] " + $cName + " u 4+ sugestija -> Score += 2");
end

rule "5.2.3b - Sugestija bez pokazivanja u 5min -> Score += 3 za sve karte"
    when
        $sug: Suggestion($sCard: suspect, $wCard: weapon, $rCard: room, $sugId: turnNumber)

        // POPRAVLJENO: Brojimo NoShow koji su se desili POSLE sugestije (koristeći temporalni operator direktno)
        Number(intValue >= 2) from accumulate(
            $ns: NoShow(suggestion == $sug, this after[0s, 5m] $sug),
            count($ns)
        )
        // POPRAVLJENO: PrivateShow se traži specifično u okviru 5 minuta od te sugestije
        not (PrivateShow(suggestion == $sug, this after[0s, 5m] $sug))

        $card: Card(this == $sCard || this == $wCard || this == $rCard, $cName: name)
        $cs: CardScore(card == $card, score > 0, score < 100)
        not ScoreApplied(ruleId == "5.2.3b", key == ($sugId + ":" + $cName))
    then
        modify($cs) { setScore($cs.getScore() + 3) };
        insert(new ScoreApplied("5.2.3b", $sugId + ":" + $cName));
        insert(new AppliedRule("5.2.3b", "sug#" + $sugId + " " + $cName + " (score+3)"));
        System.out.println("[5.2.3b] sug" + $sugId + " bez pokazivanja -> Score(" + $cName + ") += 3");
end

rule "5.2.3c - Karta pomenuta 3+ puta u roku od 15min bez Reveal-a -> Score += 2"
    when
        $card: Card($cName: name)
        Number(intValue >= 3) from accumulate(
            $s: Suggestion(suspect == $card || weapon == $card || room == $card)
                over window:time(15m),
            count($s)
        )
        not Reveal(card == $card)
        not Owns(card == $card)
        $cs: CardScore(card == $card, score > 0, score < 100)
        not ScoreApplied(ruleId == "5.2.3c", key == $cName)
        not AppliedRule(ruleId == "5.2.3h", detail == $cName)
    then
        modify($cs) { setScore($cs.getScore() + 2) };
        insert(new ScoreApplied("5.2.3c", $cName));
        insert(new AppliedRule("5.2.3c", $cName + " (score+2)"));
        System.out.println("[5.2.3c] " + $cName + " pomenuta 3+ puta -> Score += 2");
end

rule "5.2.3d - Karta potpuno nekorišćena i nepoznata 25min -> Score += 1"
    when
        // Uslov da je igra aktivna (bilo bar 9 sugestija u poslednjih 25 min)
        Number(intValue >= 9) from accumulate(
            $anySug: Suggestion() over window:time(25m),
            count($anySug)
        )
        $card: Card($cName: name)
        not Owns(card == $card)
        $cs: CardScore(card == $card, score > 0, score < 100)

        // POPRAVLJENO: Provera odsustva sugestije za specifičnu kartu u zadnjih 25 minuta
        not (Suggestion(suspect == $card || weapon == $card || room == $card) over window:time(25m))

        not ScoreApplied(ruleId == "5.2.3d", key == $cName)
    then
        modify($cs) { setScore($cs.getScore() + 1) };
        insert(new ScoreApplied("5.2.3d", $cName));
        insert(new AppliedRule("5.2.3d", $cName + " (nekorišćena 25m, score+1)"));
        System.out.println("[5.2.3d] Karta " + $cName + " se nije pojavila 25min -> Score += 1");
end

rule "5.2.3e - Sumnjivo ućutkivanje karte"
    no-loop true
    when
        $card: Card($cName: name)
        $s: CardScore(card == $card, score > 0, score < 100)

        Number(intValue >= 2) from accumulate(
            $se1: Suggestion(suspect == $card || weapon == $card || room == $card) over window:time(15m),
            count($se1)
        )

        // POPRAVLJENO: Sintaksa za odsustvo događaja u prozoru od 9 minuta
        not (Suggestion(suspect == $card || weapon == $card || room == $card) over window:time(9m))
        not (Reveal(card == $card) over window:time(9m))

        not ScoreApplied(ruleId == "5.2.3e", key == $cName)
    then
        modify($s) { setScore($s.getScore() + 1) };
        insert(new ScoreApplied("5.2.3e", $cName));
        insert(new AppliedRule("5.2.3e", $cName));
        System.out.println("[5.2.3e] Sumnjivo ućutkivanje za kartu: " + $cName + " (Score +1)");
end

rule "5.2.3f - Kumulativni NoShow kroz duži vremenski period"
    no-loop true
    when
        $card: Card($cName: name)
        $s: CardScore(card == $card, score > 0, score < 100)

        $players: java.util.Set() from accumulate(
            NoShow(
                suggestion.suspect == $card ||
                suggestion.weapon == $card ||
                suggestion.room == $card,
                $p: player
            ) over window:time(30m),
            collectSet($p)
        )
        eval($players.size() >= 3)

        not (Owns(card == $card))
        not ScoreApplied(ruleId == "5.2.3f", key == $cName)
    then
        modify($s) { setScore($s.getScore() + 2) };
        insert(new ScoreApplied("5.2.3f", $cName));
        insert(new AppliedRule("5.2.3f", $cName));
        System.out.println("[5.2.3f] Karta " + $cName + " NoShow kod 3+ igrača -> Score +2");
end

rule "5.2.3g - Recency decay (Zastarevanje sumnje)"
    no-loop true
    when
        $card: Card($cName: name)
        $s: CardScore(card == $card, score > 1, score <= 50)

        // POPRAVLJENO: Gledaju se samo akcije koje POVEĆAVAJU skor, a ne i samo ovo pravilo (izbegnut self-block)
        not (
            ScoreApplied(key == $cName, ruleId != "5.2.3g") over window:time(30m)
        )
        // Sprečava re-aktivaciju u istoj milisekundi (infinite loop zaštita)
        not ScoreApplied(ruleId == "5.2.3g", key == $cName)
    then
        modify($s) { setScore($s.getScore() - 1) };
        insert(new ScoreApplied("5.2.3g", $cName));
        insert(new AppliedRule("5.2.3g", $cName));
        System.out.println("[5.2.3g] Recency decay za kartu " + $cName + " (Score -1)");
end

rule "5.2.3h - Brzina sugestija (Brz niz / Panika)"
    salience 200
    no-loop true
    when
        $card: Card($cName: name)
        $s: CardScore(card == $card, score > 0, score < 100)

        Number(intValue >= 3) from accumulate(
            $se: Suggestion(suspect == $card || weapon == $card || room == $card) over window:time(6m),
            count($se)
        )

        not ScoreApplied(ruleId == "5.2.3h", key == $cName)
    then
        modify($s) { setScore($s.getScore() + 3) };
        insert(new ScoreApplied("5.2.3h", $cName));
        insert(new AppliedRule("5.2.3h", $cName));
        System.out.println("[5.2.3h] Detektovana panika za kartu " + $cName + " -> Score +3");
end