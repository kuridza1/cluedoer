package rules;

import com.ftn.sbnz.model.Card;
import com.ftn.sbnz.model.CardType;
import com.ftn.sbnz.model.CardScore;
import com.ftn.sbnz.model.Owns;
import com.ftn.sbnz.model.NotOwns;
import com.ftn.sbnz.model.Player;
import com.ftn.sbnz.model.Reveal;
import com.ftn.sbnz.model.NoShow;
import com.ftn.sbnz.model.PrivateShow;
import com.ftn.sbnz.model.Solution;
import com.ftn.sbnz.model.Suggestion;
import com.ftn.sbnz.model.ScoreApplied;

declare Suggestion
    @role(event)
    @timestamp(timestamp)
    @expires(2h)
end

declare Reveal
    @role(event)
    @timestamp(timestamp)
    @expires(2h)
end

declare NoShow
    @role(event)
    @timestamp(timestamp)
    @expires(2h)
end

declare PrivateShow
    @role(event)
    @timestamp(timestamp)
    @expires(2h)
end



rule "5.2.3a - Karta u 3+ sugestija bez Reveal-a -> Score += 3"
    when
        $card: Card($cName: name)
        Number(intValue >= 3) from accumulate(
            $s: Suggestion(suspect == $card || weapon == $card || room == $card)
                over window:length(10),
            count($s)
        )
        not Reveal(card == $card)
        $cs: CardScore(card == $card, score > 0)
        not ScoreApplied(ruleId == "5.2.3a", key == $cName)
    then
        modify($cs) { setScore($cs.getScore() + 3) };
        insert(new ScoreApplied("5.2.3a", $cName));
        System.out.println("[5.2.3a] " + $cName + " u 3+ sugestija bez Reveal -> Score += 3 (sada "
                + $cs.getScore() + ")");
end


rule "5.2.3b - Sugestija bez ijednog pokazivanja -> Score += 2 za sve karte"
    when
        $sug: Suggestion($sCard: suspect, $wCard: weapon, $rCard: room, $sugId: turnNumber)
        Number(intValue >= 2) from accumulate(
            $ns: NoShow(suggestion == $sug),
            count($ns)
        )
        not PrivateShow(suggestion == $sug)
        $card: Card(this == $sCard || this == $wCard || this == $rCard, $cName: name)
        $cs: CardScore(card == $card, score > 0)
        not ScoreApplied(ruleId == "5.2.3b", key == ($sugId + ":" + $cName))
    then
        modify($cs) { setScore($cs.getScore() + 2) };
        insert(new ScoreApplied("5.2.3b", $sugId + ":" + $cName));
        System.out.println("[5.2.3b] sug" + $sugId + " bez pokazivanja -> Score("
                + $cName + ") += 2 (sada " + $cs.getScore() + ")");
end

rule "5.2.3c - Karta nikad pokazana posle 6+ poteza -> Score += 1"
    when
        $card: Card($cName: name)
        Number(intValue >= 6) from accumulate(
            $s: Suggestion(),
            count($s)
        )
        not Reveal(card == $card)
        not Owns(card == $card)
        $cs: CardScore(card == $card, score > 0)
        not ScoreApplied(ruleId == "5.2.3c", key == $cName)
    then
        modify($cs) { setScore($cs.getScore() + 1) };
        insert(new ScoreApplied("5.2.3c", $cName));
        System.out.println("[5.2.3c] " + $cName + " nikad pokazana posle 6+ poteza -> Score += 1 (sada "
                + $cs.getScore() + ")");
end

