package rules;

import com.ftn.sbnz.model.Card;
import com.ftn.sbnz.model.CardType;
import com.ftn.sbnz.model.CardScore;
import com.ftn.sbnz.model.Owns;
import com.ftn.sbnz.model.NotOwns;
import com.ftn.sbnz.model.Player;
import com.ftn.sbnz.model.Reveal;
import com.ftn.sbnz.model.NoShow;
import com.ftn.sbnz.model.PrivateShow;
import com.ftn.sbnz.model.Solution;
import com.ftn.sbnz.model.Suggestion;
import com.ftn.sbnz.model.ScoreApplied;
import com.ftn.sbnz.model.AppliedRule;

declare Suggestion
    @role(event)
    @timestamp(timestamp)
    @expires(2h)
end

declare Reveal
    @role(event)
    @timestamp(timestamp)
    @expires(2h)
end

declare NoShow
    @role(event)
    @timestamp(timestamp)
    @expires(2h)
end

declare PrivateShow
    @role(event)
    @timestamp(timestamp)
    @expires(2h)
end

declare ScoreApplied
    @role(event)
    @expires(2h)
end

declare AppliedRule
    @role(event)
    @expires(2h)
end


rule "5.2.3a - Karta u 4+ sugestija u 20min bez Reveal-a -> Score += 3"
    when
        $card: Card($cName: name)
        Number(intValue >= 4) from accumulate(
            $s: Suggestion(suspect == $card || weapon == $card || room == $card)
                over window:time(20m),
            count($s)
        )
        not Reveal(card == $card)
        $cs: CardScore(card == $card, score > 0, score < 100)
        not ScoreApplied(ruleId == "5.2.3a", key == $cName)
    then
        modify($cs) { setScore($cs.getScore() + 3) };
        insert(new ScoreApplied("5.2.3a", $cName));
        insert(new AppliedRule("5.2.3a", $cName + " (score+3)"));
        System.out.println("[5.2.3a] " + $cName + " u 4+ sugestija -> Score += 3");
end

rule "5.2.3b - Karta pomenuta 3+ puta u roku od 15min bez Reveal-a -> Score += 2"
    when
        $card: Card($cName: name)
        Number(intValue >= 3) from accumulate(
            $s: Suggestion(suspect == $card || weapon == $card || room == $card)
                over window:time(15m),
            count($s)
        )
        not Reveal(card == $card)
        not Owns(card == $card)
        $cs: CardScore(card == $card, score > 0, score < 100)
        not ScoreApplied(ruleId == "5.2.3b", key == $cName)
        not AppliedRule(ruleId == "5.2.3b", detail == $cName)
    then
        modify($cs) { setScore($cs.getScore() + 2) };
        insert(new ScoreApplied("5.2.3b", $cName));
        insert(new AppliedRule("5.2.3b", $cName + " (score+2)"));
        System.out.println("[5.2.3b] " + $cName + " pomenuta 3+ puta -> Score += 2");
end


rule "5.2.3c - Brzina sugestija (Brz niz / Panika)"
    salience 200
    no-loop true
    when
        $card: Card($cName: name)
        $s: CardScore(card == $card, score > 0, score < 100)

        Number(intValue >= 3) from accumulate(
            $se: Suggestion(suspect == $card || weapon == $card || room == $card) over window:time(6m),
            count($se)
        )
        not ScoreApplied(ruleId == "5.2.3c", key == $cName)
    then
        modify($s) { setScore($s.getScore() + 3) };
        insert(new ScoreApplied("5.2.3c", $cName));
        insert(new AppliedRule("5.2.3c", $cName));
        System.out.println("[5.2.3c] Detektovana panika za kartu " + $cName + " -> Score +3");
end

rule "5.2.4a - Sugestija bez pokazivanja u 3min -> Score += 3 za sve karte"
    when
        $sug: Suggestion($sCard: suspect, $wCard: weapon, $rCard: room, $sugId: turnNumber)

        Number(intValue >= 2) from accumulate(
            $ns: NoShow(suggestion == $sug, this after[0s, 3m] $sug),
            count($ns)
        )

        $card: Card(this == $sCard || this == $wCard || this == $rCard, $cName: name)
        $cs: CardScore(card == $card, score > 0, score < 100)
        not ScoreApplied(ruleId == "5.2.4a", key == ($sugId + ":" + $cName))
    then
        modify($cs) { setScore($cs.getScore() + 3) };
        insert(new ScoreApplied("5.2.4a", $sugId + ":" + $cName));
        insert(new AppliedRule("5.2.4a", "sug#" + $sugId + " " + $cName + " (score+3)"));
        System.out.println("[5.2.4a] sug" + $sugId + " bez pokazivanja -> Score(" + $cName + ") += 3");
end

rule "5.2.4b - Kumulativni NoShow kroz duži vremenski period"
    no-loop true
    when
        $card: Card($cName: name)
        $s: CardScore(card == $card, score > 0, score < 100)

        $players: java.util.Set() from accumulate(
            NoShow(
                suggestion.suspect == $card ||
                suggestion.weapon == $card ||
                suggestion.room == $card,
                $p: player
            ) over window:time(30m),
            collectSet($p)
        )
        eval($players.size() >= 3)

        not (Owns(card == $card))
        not ScoreApplied(ruleId == "5.2.4b", key == $cName)
    then
        modify($s) { setScore($s.getScore() + 2) };
        insert(new ScoreApplied("5.2.4b", $cName));
        insert(new AppliedRule("5.2.4b", $cName));
        System.out.println("[5.2.4b] Karta " + $cName + " NoShow kod 3+ igrača -> Score +2");
end

rule "5.2.5a - Karta potpuno nekorišćena i nepoznata 25min -> Score += 1"
    when
        Number(intValue >= 9) from accumulate(
            $anySug: Suggestion() over window:time(25m),
            count($anySug)
        )
        $card: Card($cName: name)
        not Owns(card == $card)
        $cs: CardScore(card == $card, score > 0, score < 100)

        not (Suggestion(suspect == $card || weapon == $card || room == $card) over window:time(25m))

        not ScoreApplied(ruleId == "5.2.5a", key == $cName)
    then
        modify($cs) { setScore($cs.getScore() + 1) };
        insert(new ScoreApplied("5.2.5a", $cName));
        insert(new AppliedRule("5.2.5a", $cName + " (nekorišćena 25m, score+1)"));
        System.out.println("[5.2.5a] Karta " + $cName + " se nije pojavila 25min -> Score += 1");
end

rule "5.2.5b - Sumnjivo ućutkivanje karte"
    no-loop true
    when
        $card: Card($cName: name)
        $s: CardScore(card == $card, score > 0, score < 100)

        Number(intValue >= 2) from accumulate(
            $se1: Suggestion(suspect == $card || weapon == $card || room == $card) over window:time(15m),
            count($se1)
        )

        not (Suggestion(suspect == $card || weapon == $card || room == $card) over window:time(9m))
        not (Reveal(card == $card) over window:time(9m))

        not ScoreApplied(ruleId == "5.2.5b", key == $cName)
    then
        modify($s) { setScore($s.getScore() + 1) };
        insert(new ScoreApplied("5.2.5b", $cName));
        insert(new AppliedRule("5.2.5b", $cName));
        System.out.println("[5.2.5b] Sumnjivo ućutkivanje za kartu: " + $cName + " (Score +1)");
end



rule "5.2.5c - Recency decay (Zastarevanje sumnje)"
    no-loop true
    when
        $card: Card($cName: name)
        $s: CardScore(card == $card, score > 1, score <= 50)
        not (
            ScoreApplied(key == $cName, ruleId != "5.2.3g") over window:time(30m)
        )
        not ScoreApplied(ruleId == "5.2.3g", key == $cName)
    then
        modify($s) { setScore($s.getScore() - 1) };
        insert(new ScoreApplied("5.2.5c", $cName));
        insert(new AppliedRule("5.2.5c", $cName));
        System.out.println("[5.2.5c] Recency decay za kartu " + $cName + " (Score -1)");
end
